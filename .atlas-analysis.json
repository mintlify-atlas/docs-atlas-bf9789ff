  "keyFeatures": [
    "Real-time usage metering with high-volume event ingestion",
    "Flexible pricing models (usage-based, seat-based, hybrid)",
    "Prepaid and promotional credit management with wallets",
    "Feature gating and entitlement management",
    "Automated invoice generation and billing cycles",
    "Integration with payment providers (Stripe, Chargebee, Razorpay)",
    "Multi-tenant architecture with environment isolation",
    "Self-hostable open-source platform (AGPLv3)",
    "Workflow orchestration via Temporal",
    "Real-time analytics with ClickHouse"
  ],
  "publicApiSurface": [
    "POST /v1/events - Ingest usage events",
    "POST /v1/events/batch - Batch event ingestion",
    "GET /v1/events - Query events",
    "POST /v1/customers - Create customer",
    "GET /v1/customers - List customers",
    "GET /v1/customers/{id} - Get customer",
    "POST /v1/meters - Create meter",
    "GET /v1/meters - List meters",
    "POST /v1/plans - Create pricing plan",
    "GET /v1/plans - List plans",
    "POST /v1/subscriptions - Create subscription",
    "GET /v1/subscriptions - List subscriptions",
    "PUT /v1/subscriptions/{id}/cancel - Cancel subscription",
    "GET /v1/invoices - List invoices",
    "GET /v1/invoices/{id} - Get invoice",
    "POST /v1/wallets - Create wallet",
    "POST /v1/credit-grants - Grant credits",
    "POST /v1/features - Create feature",
    "GET /v1/features/check-access - Check feature access",
    "POST /v1/prices - Create price",
    "POST /v1/coupons - Create coupon",
    "GET /v1/health - Health check"
  ]
